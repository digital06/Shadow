# ============================================================
# Frontend environment variables (public, exposed in the build)
# ============================================================
# These are READ by the Vite build. Anything prefixed with VITE_
# will be embedded into the JS bundle and visible in the browser.
# DO NOT put secrets (like TIP4SERV_API_KEY) here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# Server secrets (NOT read here - reminder only)
# ============================================================
# The following secret MUST be configured in Supabase Edge
# Function secrets (see SETUP.md), NOT in this file:
#
#   TIP4SERV_API_KEY   -> your Tip4Serv API key
#
# Set it via the Supabase Dashboard or:
#   supabase secrets set TIP4SERV_API_KEY=... --project-ref <ref>
